{
  "name": "@bstockwelldev/react-skin-system",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Framework-neutral React runtime for html[data-skin] theming, persistence, boot overlay, and cycling.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bstockwelldev/react-skin-system.git"
  },
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next/bootstrap.d.ts",
      "import": "./dist/next/bootstrap.js",
      "require": "./dist/next/bootstrap.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "changesets": "^1.0.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "react",
    "theme",
    "skin",
    "data-skin",
    "nextjs",
    "vite"
  ]
}
